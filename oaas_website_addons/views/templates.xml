        <template id="my_slideshow_template" inherit_id="website.layout">
            <xpath expr="//head" position="inside">
                <link rel="stylesheet" type="text/css" href="/oaas_website_addons/static/src/css/my_slideshow_template.css?v=tech-4x4-png-v2"/>
            </xpath>
        </template>

        <template id="brand_promotion" inherit_id="website.brand_promotion">
            <xpath expr="//t[@t-call='web.brand_promotion_message']" position="replace">
            </xpath>
        </template>

